<!-- ===== BẢNG GIÁ DỊCH VỤ ===== -->
<% if (pricing && pricing.length > 0) { %>
<section class="pricing-section">
  <div class="pricing-inner">
    <div class="pricing-heading">
      <p class="pricing-heading__tag">Bảng giá</p>
      <h2>Gói dịch vụ <span>thiết kế website</span></h2>
      <p>Chọn gói phù hợp với nhu cầu và ngân sách của doanh nghiệp bạn. Tất cả gói đều bao gồm hỗ trợ sau bàn giao.</p>
    </div>
    <div class="pricing-grid">
      <% pricing.forEach(function(pkg) { %>
      <div class="pricing-card <%= pkg.is_featured ? 'pricing-card--featured' : '' %>">
        <% if (pkg.badge) { %>
          <span class="pricing-card__badge"><%= pkg.badge %></span>
        <% } %>
        <div class="pricing-card__head">
          <h3><%= pkg.name %></h3>
          <p><%= pkg.description %></p>
        </div>
        <div class="pricing-card__price">
          <span class="pricing-card__amount"><%= Number(pkg.price).toLocaleString('vi-VN') %>đ</span>
          <span class="pricing-card__unit">/ <%= pkg.unit %></span>
        </div>
        <ul class="pricing-card__features">
          <% pkg.features.forEach(function(f) { %>
          <li>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
            <%= f %>
          </li>
          <% }); %>
        </ul>
        <a href="/lien-he" class="pricing-card__btn">Đăng ký ngay</a>
      </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- ===== BLOG NỔI BẬT ===== -->
<% if (typeof featuredPosts !== 'undefined' && featuredPosts && featuredPosts.length > 0) { %>
<section class="home-blog">
  <div class="home-blog__inner">
    <div class="home-blog__heading">
      <div>
        <p class="home-blog__tag">Tin tức</p>
        <h2>Bài viết <span>nổi bật</span></h2>
      </div>
      <a href="/blog" class="home-blog__more">Xem tất cả &rarr;</a>
    </div>
    <div class="home-blog__grid">
      <% featuredPosts.forEach(function(post, i) { %>
      <article class="blog-card">
        <a href="/blog/<%= post.slug %>" class="blog-card__img">
          <img src="<%= post.thumbnail || '/images/default.png' %>" alt="<%= post.title %>">
        </a>
        <div class="blog-card__body">
          <div class="blog-card__meta">
            <span><%= new Date(post.created_at).toLocaleDateString('vi-VN') %></span>
          </div>
          <h3 class="blog-card__title"><a href="/blog/<%= post.slug %>"><%= post.title %></a></h3>
          <p class="blog-card__desc"><%= (post.description || '').substring(0, 100) %><%= post.description && post.description.length > 100 ? '...' : '' %></p>
          <a href="/blog/<%= post.slug %>" class="blog-card__btn">Đọc tiếp &rarr;</a>
        </div>
      </article>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

