<!-- ===== QUY TRÌNH THIẾT KẾ ===== -->
<section class="process-section">
  <div class="process-inner">

    <div class="process-label">
      <p class="process-label__tag">Quy trình</p>
      <h2>Thiết kế website</h2>
      <p class="process-label__sub">Chỉ với 5 bước đơn giản dưới đây bạn đã sở hữu một website chuyên nghiệp.</p>
      <div class="process-label__img">
        <img src="/images/procedure.avif" alt="Quy trình thiết kế website">
      </div>
    </div>

    <div class="process-steps">
      <% if (typeof processSteps !== 'undefined' && processSteps && processSteps.length > 0) { %>
        <% const shiftMap = [0, 120, 240, 120, 0, 120, 240, 120, 0]; %>
        <% processSteps.forEach(function(step, i) { %>
        <div class="process-row" style="<%= shiftMap[i % shiftMap.length] > 0 ? 'margin-left:' + shiftMap[i % shiftMap.length] + 'px' : '' %>">
          <div class="process-step__cube process-cube--<%= step.color %>"><%= String(step.step_number).padStart(2,'0') %></div>
          <% if (step.image_path) { %>
          <div class="process-step__img"><img src="<%= step.image_path %>" alt="<%= step.title %>"></div>
          <% } %>
          <div class="process-step__info">
            <span>BƯỚC <%= String(step.step_number).padStart(2,'0') %></span>
            <h4><%= step.title %></h4>
            <p><%= step.description %></p>
          </div>
        </div>
        <% }); %>
      <% } %>
    </div>
  </div>
</section>

