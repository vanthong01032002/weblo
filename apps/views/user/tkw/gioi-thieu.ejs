<!-- Tại sao chọn Devora -->
<section class="tkw-why">
  <div class="tkw-inner">
    <div class="tkw-section-head">
      <p class="tkw-tag">Tại sao chọn chúng tôi</p>
      <h2>Devora — Đối tác thiết kế website <span>đáng tin cậy</span></h2>
      <p>Chúng tôi không chỉ tạo ra website đẹp, mà còn xây dựng nền tảng số giúp doanh nghiệp tăng trưởng bền vững.</p>
    </div>
    <div class="tkw-why__grid">
      <div class="tkw-why-card">
        <div class="tkw-why-card__icon" style="background:#e8f0fe;color:#1565c0;">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <h4>Chuẩn SEO từ nền tảng</h4>
        <p>Mỗi website được xây dựng với cấu trúc SEO tối ưu ngay từ đầu, giúp tăng thứ hạng tìm kiếm tự nhiên.</p>
      </div>
      <div class="tkw-why-card">
        <div class="tkw-why-card__icon" style="background:#e0f7fa;color:#00838f;">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14z"/></svg>
        </div>
        <h4>Responsive mọi thiết bị</h4>
        <p>Giao diện tự động thích ứng hoàn hảo trên desktop, tablet và mobile, đảm bảo trải nghiệm tốt nhất.</p>
      </div>
      <div class="tkw-why-card">
        <div class="tkw-why-card__icon" style="background:#fff3e0;color:#e65100;">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2.05v2.02c3.95.49 7 3.85 7 7.93 0 3.21-1.81 6-4.72 7.28L13 17v5h5l-1.22-1.22C19.91 19.07 22 15.76 22 12c0-5.18-3.95-9.45-9-9.95zM11 2.05C5.95 2.55 2 6.82 2 12c0 3.76 2.09 7.07 5.22 8.78L6 22h5v-5l-2.28 2.28C7.81 18 6 15.21 6 12c0-4.08 3.05-7.44 7-7.93V2.05z"/></svg>
        </div>
        <h4>Tốc độ tải nhanh</h4>
        <p>Tối ưu hiệu suất, nén ảnh và code để website tải nhanh, cải thiện điểm Core Web Vitals.</p>
      </div>
      <div class="tkw-why-card">
        <div class="tkw-why-card__icon" style="background:#f3e5f5;color:#6a1b9a;">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
        </div>
        <h4>Bảo mật cao</h4>
        <p>SSL, bảo vệ dữ liệu và cập nhật bảo mật định kỳ để website luôn an toàn trước các mối đe dọa.</p>
      </div>
      <div class="tkw-why-card">
        <div class="tkw-why-card__icon" style="background:#e8f5e9;color:#2e7d32;">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
        </div>
        <h4>Hỗ trợ tận tâm</h4>
        <p>Đội ngũ hỗ trợ 24/7, phản hồi nhanh chóng và đồng hành cùng bạn sau khi bàn giao website.</p>
      </div>
      <div class="tkw-why-card">
        <div class="tkw-why-card__icon" style="background:#fce4ec;color:#c62828;">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
        </div>
        <h4>Chi phí hợp lý</h4>
        <p>Gói dịch vụ đa dạng phù hợp mọi ngân sách, từ startup đến doanh nghiệp lớn.</p>
      </div>
    </div>
  </div>
</section>

<!-- Quy trình -->
<section class="tkw-process">
  <div class="tkw-inner">
    <div class="tkw-section-head">
      <p class="tkw-tag">Quy trình làm việc</p>
      <h2>5 bước để có website <span>chuyên nghiệp</span></h2>
    </div>
    <div class="tkw-steps">
      <% const steps = [
        { n:'01', title:'Tư vấn & Phân tích', desc:'Lắng nghe nhu cầu, phân tích thị trường và đề xuất giải pháp phù hợp.' },
        { n:'02', title:'Thiết kế giao diện', desc:'Thiết kế UI/UX chuẩn thương hiệu, trình bày để khách hàng duyệt.' },
        { n:'03', title:'Lập trình & Tích hợp', desc:'Phát triển website với code sạch, tích hợp đầy đủ tính năng yêu cầu.' },
        { n:'04', title:'Kiểm tra & Tối ưu', desc:'Test kỹ lưỡng trên mọi thiết bị, tối ưu tốc độ và SEO.' },
        { n:'05', title:'Bàn giao & Hỗ trợ', desc:'Bàn giao toàn bộ mã nguồn, đào tạo quản trị và hỗ trợ sau bàn giao.' },
      ]; %>
      <% steps.forEach(function(s, i) { %>
      <div class="tkw-step">
        <div class="tkw-step__num"><%= s.n %></div>
        <% if (i < steps.length - 1) { %><div class="tkw-step__line"></div><% } %>
        <h4><%= s.title %></h4>
        <p><%= s.desc %></p>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="tkw-cta">
  <div class="tkw-cta__inner">
    <h2>Sẵn sàng xây dựng website cho doanh nghiệp?</h2>
    <p>Liên hệ ngay để được tư vấn miễn phí và nhận báo giá chi tiết.</p>
    <div class="tkw-cta__btns">
      <a href="/lien-he" class="tkw-btn tkw-btn--white">Liên hệ tư vấn</a>
      <a href="/thiet-ke-website/bang-gia" class="tkw-btn tkw-btn--outline-white">Xem bảng giá</a>
    </div>
  </div>
</section>
