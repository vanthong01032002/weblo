<!-- ===== HERO ===== -->
<section class="kh-hero">
  <div class="kh-hero__inner">
    <p class="kh-hero__tag">100+ Dự án thành công</p>
    <h1>Khách hàng của <span>Devora</span></h1>
    <p>Với Devora, mỗi dự án hoàn thành không chỉ là một sản phẩm công nghệ, mà là một lời cảm ơn gửi đến Quý khách hàng. Chúng tôi trân trọng cơ hội được lắng nghe, thấu hiểu và cùng bạn xây dựng một nền tảng website chuyên nghiệp, vững chắc cho sự phát triển lâu dài.</p>
  </div>
</section>

<!-- ===== STATS ===== -->
<section class="kh-stats">
  <div class="kh-stats__inner">
    <div class="kh-stat">
      <span class="kh-stat__num">100+</span>
      <span class="kh-stat__label">Website đã triển khai</span>
    </div>
    <div class="kh-stat">
      <span class="kh-stat__num">100%</span>
      <span class="kh-stat__label">Khách hàng hài lòng</span>
    </div>
    <div class="kh-stat">
      <span class="kh-stat__num">95%</span>
      <span class="kh-stat__label">Tăng trưởng doanh thu</span>
    </div>
    <div class="kh-stat">
      <span class="kh-stat__num">10+</span>
      <span class="kh-stat__label">Lĩnh vực đa ngành</span>
    </div>
  </div>
</section>

<!-- ===== TESTIMONIALS ===== -->
<section class="kh-testimonials">
  <div class="kh-section__inner">
    <div class="kh-section__heading">
      <h2>Những câu chuyện thành công từ các dự án thực tế</h2>
      <p>Cảm ơn vì đã tin tưởng và đồng hành cùng Devora. Mỗi lời chia sẻ là sự ghi nhận quý giá dành cho chúng tôi.</p>
    </div>

    <div class="kh-testimonials__grid">
      <% if (typeof clients !== 'undefined' && clients && clients.length > 0) { %>
        <% clients.forEach(function(c, i) { %>
        <div class="kh-testi-card <%= i === 0 ? 'kh-testi-card--featured' : '' %>">
          <div class="kh-testi-card__quote">"</div>
          <p><%= c.testimonial || '' %></p>
          <div class="kh-testi-card__author">
            <% if (c.avatar) { %>
              <img src="<%= c.avatar %>" class="kh-testi-card__avatar" style="width:44px;height:44px;min-width:44px;border-radius:50%;object-fit:cover;flex-shrink:0;" alt="<%= c.full_name %>">
            <% } else { %>
              <div class="kh-testi-card__avatar"><%= c.full_name.charAt(0).toUpperCase() %></div>
            <% } %>
            <div>
              <strong><%= c.full_name %></strong>
              <span><%= [c.position, c.company].filter(Boolean).join(' - ') %></span>
            </div>
          </div>
          <div class="kh-testi-card__stars">
            <% for(let s=0;s<5;s++){ %><%= s < c.rating ? '★' : '☆' %><% } %>
          </div>
        </div>
        <% }); %>
      <% } else { %>
        <p style="grid-column:1/-1;text-align:center;color:#aaa;padding:40px 0;">Chưa có đánh giá nào.</p>
      <% } %>
    </div>
  </div>
</section>

