<!-- Hero -->
<section class="contact-hero" <% if (contactPage && contactPage.image_path) { %>style="background-image: linear-gradient(rgba(13,45,94,0.75), rgba(13,45,94,0.75)), url('<%= contactPage.image_path %>'); background-size:cover; background-position:center;"<% } %>>
  <div class="contact-hero__inner">
    <h1><%= contactPage && contactPage.title ? contactPage.title : 'Liên hệ với chúng tôi' %></h1>
    <p><%= contactPage && contactPage.description ? contactPage.description : 'Hãy để lại thông tin, chúng tôi sẽ liên hệ lại sớm nhất.' %></p>
  </div>
</section>

<!-- Content -->
<section class="contact-section">
  <div class="contact-inner">

    <!-- Info -->
    <div class="contact-info">
      <h2>Thông tin liên hệ</h2>

      <div class="contact-info__item">
        <div class="contact-info__icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
        <div>
          <strong>Địa chỉ</strong>
          <p><%= (typeof settings !== 'undefined' && settings.address) ? settings.address : '213 Chu Văn An, Phường 26, Quận Bình Thạnh, TPHCM' %></p>
        </div>
      </div>

      <div class="contact-info__item">
        <div class="contact-info__icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        </div>
        <div>
          <strong>Điện thoại</strong>
          <p><a href="tel:<%= (typeof settings !== 'undefined' && settings.hotline) ? settings.hotline.replace(/\./g,'') : '' %>"><%= (typeof settings !== 'undefined' && settings.hotline) ? settings.hotline : '0912.817.117' %></a></p>
        </div>
      </div>

      <div class="contact-info__item">
        <div class="contact-info__icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </div>
        <div>
          <strong>Email</strong>
          <p><a href="mailto:<%= (typeof settings !== 'undefined' && settings.email) ? settings.email : 'info@devora.vn' %>"><%= (typeof settings !== 'undefined' && settings.email) ? settings.email : 'info@devora.vn' %></a></p>
        </div>
      </div>

      <div class="contact-info__item">
        <div class="contact-info__icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
        </div>
        <div>
          <strong>Giờ làm việc</strong>
          <p><%= (typeof settings !== 'undefined' && settings.working_hours) ? settings.working_hours : '8h00 - 17h30 (Thứ 2 - Thứ 7)' %></p>
        </div>
      </div>
    </div>

    <!-- Form -->
    <div class="contact-form-wrap">
      <h2>Gửi tin nhắn cho chúng tôi</h2>

      <% if (typeof sent !== 'undefined' && sent) { %>
      <div class="contact-success">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
        Cảm ơn bạn! Chúng tôi đã nhận được tin nhắn và sẽ liên hệ lại sớm.
      </div>
      <% } %>

      <form action="/lien-he" method="POST" class="contact-form" id="contactForm">
        <div class="contact-form__row contact-form__row--half">
          <div>
            <label>Họ và tên <span>*</span></label>
            <input type="text" name="full_name" required placeholder="Nguyễn Văn A">
          </div>
          <div>
            <label>Số điện thoại</label>
            <input type="tel" name="phone" placeholder="0912.xxx.xxx">
          </div>
        </div>
        <div class="contact-form__row">
          <label>Email</label>
          <input type="email" name="email" placeholder="email@example.com">
        </div>
        <div class="contact-form__row">
          <label>Chủ đề</label>
          <input type="text" name="subject" placeholder="Tôi muốn tư vấn về...">
        </div>
        <div class="contact-form__row">
          <label>Nội dung <span>*</span></label>
          <textarea name="message" rows="5" required placeholder="Nội dung tin nhắn của bạn..."></textarea>
        </div>
        <button type="submit" class="contact-form__btn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          Gửi tin nhắn
        </button>
      </form>
    </div>

  </div>
</section>
