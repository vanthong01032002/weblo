          <div class="kgd-card__overlay">
            <a href="#" class="kgd-card__preview">Xem trước</a>
            <a href="/lien-he" class="kgd-card__use">Dùng mẫu này</a>
          </div>
          <span class="kgd-card__badge">Ưa chuộng</span>
        </div>
        <div class="kgd-card__body">
          <span class="kgd-card__cat">F&B</span>
          <h4>Mẫu website F&B 1</h4>
