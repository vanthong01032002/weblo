<!-- ===== KHO THEO LĨNH VỰC ===== -->
<section class="kgd-catalog">
  <div class="kgd-inner">
    <div class="kgd-section__heading">
      <h2>Khám phá theo <span>lĩnh vực</span></h2>
      <p>Webtop phân chia thư viện mẫu website theo các nhóm ngành hàng thông dụng</p>
    </div>

    <!-- Filter tabs -->
    <div class="kgd-filters" id="kgdFilters">
      <button class="kgd-filter active" data-filter="all">Tất cả</button>
      <button class="kgd-filter" data-filter="bds">Bất động sản</button>
      <button class="kgd-filter" data-filter="fnb">F&B</button>
      <button class="kgd-filter" data-filter="noithat">Nội thất</button>
      <button class="kgd-filter" data-filter="dulich">Du lịch</button>
      <button class="kgd-filter" data-filter="giaoduc">Giáo dục</button>
      <button class="kgd-filter" data-filter="lamdep">Làm đẹp</button>
      <button class="kgd-filter" data-filter="banhang">Bán hàng</button>
      <button class="kgd-filter" data-filter="khac">Khác</button>
    </div>

    <!-- Grid -->
    <div class="kgd-grid" id="kgdGrid">

      <% const templates = [
        { cat: 'bds',     catLabel: 'Bất động sản', name: 'Mẫu website BĐS 1',       uses: 29, img: '/images/banner_main.jpg',  hot: true  },
        { cat: 'fnb',     catLabel: 'F&B',           name: 'Mẫu website F&B 1',        uses: 28, img: '/images/hero-main.png',    hot: true  },
        { cat: 'xaydung', catLabel: 'Xây dựng',      name: 'Mẫu website xây dựng 1',  uses: 19, img: '/images/tab-combo1.png',   hot: false },
        { cat: 'noithat', catLabel: 'Nội thất',       name: 'Mẫu website nội thất 1',  uses: 24, img: '/images/tab-combo2.png',   hot: false },
        { cat: 'fnb',     catLabel: 'F&B',            name: 'Mẫu website F&B 4',        uses: 21, img: '/images/tab-monchay.png',  hot: false },
        { cat: 'lamdep',  catLabel: 'Làm đẹp',        name: 'Mẫu website studio 1',    uses: 15, img: '/images/hero-small.png',   hot: false },
        { cat: 'dulich',  catLabel: 'Du lịch',         name: 'Mẫu website du lịch 1',   uses: 26, img: '/images/tab-combo1.png',   hot: false },
        { cat: 'khac',    catLabel: 'Khách sạn',       name: 'Mẫu website khách sạn 1', uses: 18, img: '/images/tab-combo2.png',   hot: false },
        { cat: 'fnb',     catLabel: 'F&B',             name: 'Mẫu website F&B 2',        uses: 14, img: '/images/banner_main.jpg',  hot: false },
        { cat: 'khac',    catLabel: 'Bảo hiểm',        name: 'Mẫu website bảo hiểm 1',  uses: 7,  img: '/images/hero-main.png',    hot: false },
        { cat: 'khac',    catLabel: 'Vận tải',          name: 'Mẫu website vận tải 1',   uses: 9,  img: '/images/tab-monchay.png',  hot: false },
        { cat: 'noithat', catLabel: 'Nội thất',         name: 'Mẫu website nội thất 2',  uses: 25, img: '/images/tab-combo1.png',   hot: false },
        { cat: 'bds',     catLabel: 'Bất động sản',     name: 'Mẫu website BĐS 2',       uses: 16, img: '/images/tab-combo2.png',   hot: false },
        { cat: 'giaoduc', catLabel: 'Giáo dục',         name: 'Mẫu website giáo dục 1',  uses: 13, img: '/images/hero-small.png',   hot: false },
        { cat: 'fnb',     catLabel: 'F&B',              name: 'Mẫu website F&B 5',        uses: 27, img: '/images/banner_main.jpg',  hot: true  },
        { cat: 'banhang', catLabel: 'Bán hàng',         name: 'Mẫu website bán hàng 1',  uses: 19, img: '/images/hero-main.png',    hot: false },
        { cat: 'lamdep',  catLabel: 'Làm đẹp',          name: 'Mẫu website làm đẹp 1',   uses: 26, img: '/images/tab-combo1.png',   hot: true  },
        { cat: 'banhang', catLabel: 'Bán hàng',         name: 'Mẫu website bán hàng 2',  uses: 23, img: '/images/tab-combo2.png',   hot: false },
        { cat: 'dulich',  catLabel: 'Du lịch',           name: 'Mẫu website du lịch 2',   uses: 23, img: '/images/tab-monchay.png',  hot: false },
        { cat: 'bds',     catLabel: 'Bất động sản',      name: 'Mẫu website BĐS 3',       uses: 24, img: '/images/hero-small.png',   hot: false },
      ]; %>

      <% templates.forEach(function(t) { %>
      <div class="kgd-card" data-cat="<%= t.cat %>" data-name="<%= t.name.toLowerCase() %>">
        <div class="kgd-card__img">
          <img src="<%= t.img %>" alt="<%= t.name %>">
          <div class="kgd-card__overlay">
            <a href="#" class="kgd-card__preview">Xem trước</a>
            <a href="/lien-he" class="kgd-card__use">Dùng mẫu này</a>
          </div>
          <% if (t.hot) { %><span class="kgd-card__badge">Ưa chuộng</span><% } %>
        </div>
        <div class="kgd-card__body">
          <span class="kgd-card__cat"><%= t.catLabel %></span>
          <h4><%= t.name %></h4>
          <div class="kgd-card__meta">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
            <%= t.uses %> lượt sử dụng
          </div>
        </div>
      </div>
      <% }); %>

    </div>

    <div class="kgd-empty" id="kgdEmpty" style="display:none;">
      <p>Không tìm thấy mẫu phù hợp.</p>
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="kgd-cta">
  <div class="kgd-cta__inner">
    <h2>Không tìm thấy mẫu phù hợp?</h2>
    <p>Webtop có thể thiết kế riêng cho bạn một giao diện độc đáo, phù hợp hoàn toàn với thương hiệu và ngành nghề của bạn.</p>
    <a href="/lien-he" class="kgd-cta__btn">Yêu cầu thiết kế riêng</a>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const filters = document.querySelectorAll('.kgd-filter');
  const cards   = document.querySelectorAll('#kgdGrid .kgd-card');
  const empty   = document.getElementById('kgdEmpty');
  const search  = document.getElementById('kgdSearch');
  let activeFilter = 'all';

  function applyFilter() {
    const q = search.value.toLowerCase().trim();
    let visible = 0;
    cards.forEach(function (card) {
      const matchCat  = activeFilter === 'all' || card.dataset.cat === activeFilter;
      const matchName = !q || card.dataset.name.includes(q);
      const show = matchCat && matchName;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    empty.style.display = visible === 0 ? 'block' : 'none';
  }

  filters.forEach(function (btn) {
    btn.addEventListener('click', function () {
      filters.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      activeFilter = btn.dataset.filter;
      applyFilter();
    });
  });

  search.addEventListener('input', applyFilter);
});
</script>
