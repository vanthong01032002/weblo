<section class="admin-panel">
  <div class="admin-panel__head">
    <h1 class="admin-panel__title">Quản lý / Tin tức</h1>
    <hr class="admin-panel__rule">
  </div>

  <% if (success) { %><div class="admin-alert admin-alert--success"><%= success %></div><% } %>
  <% if (error) { %><div class="admin-alert admin-alert--error"><%= error %></div><% } %>

  <div class="admin-panel__toolbar">
    <a href="/admin/content/news/create" class="admin-btn admin-btn--green">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
      Thêm bài viết
    </a>
  </div>

  <div class="admin-panel__search">
    <label>Tìm kiếm danh mục</label>
    <div class="admin-search-box">
      <input type="text" id="searchInput" placeholder="Tìm kiếm...">
      <button><svg viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg></button>
    </div>
  </div>

  <div class="admin-table-wrap">
    <table class="admin-table" id="blogTable">
      <thead>
        <tr>
          <th width="36"><input type="checkbox" id="checkAll"></th>
          <th width="60">STT</th>
          <th>TIÊU ĐỀ</th>
          <th width="100">HÌNH ẢNH</th>
          <th width="100">NỔI BẬT</th>
          <th width="100">HIỂN THỊ</th>
          <th width="120">THAO TÁC</th>
        </tr>
      </thead>
      <tbody>
        <% if (posts.length === 0) { %>
        <tr><td colspan="7" class="admin-table__empty">Chưa có bài viết nào</td></tr>
        <% } %>
        <% posts.forEach(function(post, i) { %>
        <tr data-title="<%= post.title.toLowerCase() %>">
          <td><input type="checkbox" class="row-check" value="<%= post.id %>"></td>
          <td><%= i + 1 %></td>
          <td>
            <strong><%= post.title %></strong>
            <div class="blog-row-actions">
              <a href="/blog/<%= post.slug %>" target="_blank" class="blog-action-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg> View
              </a>
              <a href="/admin/content/news/edit/<%= post.id %>" class="blog-action-link blog-action-link--edit">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg> Edit
              </a>
            </div>
          </td>
          <td>
            <% if (post.thumbnail) { %>
              <img src="<%= post.thumbnail %>" class="admin-thumb" alt="">
            <% } else { %>
              <div class="admin-thumb-empty">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                <span>Chưa có ảnh</span>
              </div>
            <% } %>
          </td>
          <td>
            <label class="admin-toggle">
              <input type="checkbox" class="toggle-featured" data-id="<%= post.id %>" <%= post.is_featured ? 'checked' : '' %>>
              <span class="admin-toggle__slider"></span>
            </label>
          </td>
          <td>
            <label class="admin-toggle">
              <input type="checkbox" class="toggle-active" data-id="<%= post.id %>" <%= post.is_active ? 'checked' : '' %>>
              <span class="admin-toggle__slider"></span>
            </label>
          </td>
          <td class="admin-table__actions">
            <a href="/admin/content/news/edit/<%= post.id %>" class="admin-action admin-action--edit" title="Sửa">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
            </a>
            <button class="admin-action admin-action--delete btn-delete" data-id="<%= post.id %>" title="Xóa">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
            </button>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</section>

<script>
document.getElementById('searchInput').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('#blogTable tbody tr[data-title]').forEach(r => {
    r.style.display = r.dataset.title.includes(q) ? '' : 'none';
  });
});

document.getElementById('checkAll').addEventListener('change', function() {
  document.querySelectorAll('.row-check').forEach(cb => cb.checked = this.checked);
});

document.querySelectorAll('.toggle-active').forEach(t => {
  t.addEventListener('change', function() {
    fetch('/admin/content/news/toggle-active/' + this.dataset.id, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ is_active: this.checked ? 1 : 0 })
    });
  });
});

document.querySelectorAll('.toggle-featured').forEach(t => {
  t.addEventListener('change', function() {
    fetch('/admin/content/news/toggle-featured/' + this.dataset.id, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ is_featured: this.checked ? 1 : 0 })
    });
  });
});

document.querySelectorAll('.btn-delete').forEach(btn => {
  btn.addEventListener('click', function() {
    if (!confirm('Xóa bài viết này?')) return;
    fetch('/admin/content/news/' + this.dataset.id, { method: 'DELETE' })
      .then(r => r.json()).then(d => { if (d.success) location.reload(); });
  });
});
</script>
