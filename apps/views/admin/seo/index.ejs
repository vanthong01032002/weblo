<section class="admin-panel">
  <div class="admin-panel__head">
    <h1 class="admin-panel__title">Quản lý SEO / <%= pageInfo.label %></h1>
    <hr class="admin-panel__rule">
  </div>

  <% if (success) { %><div class="admin-alert admin-alert--success"><%= success %></div><% } %>
  <% if (error) { %><div class="admin-alert admin-alert--error"><%= error %></div><% } %>

  <form action="/admin/seo-pages/<%= key %>" method="POST" enctype="multipart/form-data">
    <div class="seo-admin-layout">

      <!-- Left: thông tin -->
      <div class="seo-admin-info">
        <div class="seo-admin-tab">Tiếng Việt</div>

        <div class="admin-form__row">
          <label class="admin-form__label">Title (vi) :</label>
          <input type="text" name="title" id="seoTitle" class="admin-form__input"
                 value="<%= seo.title || '' %>" placeholder="Tiêu đề SEO trang">
          <div class="seo-admin-counter"><span id="cntTitle"><%= (seo.title || '').length %></span> / 70 ký tự</div>
          <div class="seo-bar"><div class="seo-bar__fill" id="barTitle" style="width:<%= Math.min((seo.title||'').length/70*100,100) %>%"></div></div>
        </div>

        <div class="admin-form__row">
          <label class="admin-form__label">Keywords (vi) :</label>
          <input type="text" name="keywords" id="seoKeywords" class="admin-form__input"
                 value="<%= seo.keywords || '' %>" placeholder="từ khóa 1, từ khóa 2, ...">
          <div class="seo-admin-counter"><span id="cntKeywords"><%= (seo.keywords || '').length %></span> / 160 ký tự</div>
          <div class="seo-bar"><div class="seo-bar__fill" id="barKeywords" style="width:<%= Math.min((seo.keywords||'').length/160*100,100) %>%"></div></div>
        </div>

        <div class="admin-form__row">
          <label class="admin-form__label">Description (vi) :</label>
          <textarea name="description" id="seoDesc" class="admin-form__input admin-form__textarea" rows="5"
                    placeholder="Mô tả SEO trang (tối đa 160 ký tự)"><%= seo.description || '' %></textarea>
          <div class="seo-admin-counter"><span id="cntDesc"><%= (seo.description || '').length %></span> / 160 ký tự</div>
          <div class="seo-bar"><div class="seo-bar__fill" id="barDesc" style="width:<%= Math.min((seo.description||'').length/160*100,100) %>%"></div></div>
        </div>

        <!-- Google preview -->
        <div class="seo-google-preview">
          <p class="seo-google-preview__label">Xem trước Google:</p>
          <div class="seo-preview">
            <div class="seo-preview__title" id="prevTitle"><%= seo.title || 'Tiêu đề trang' %></div>
            <div class="seo-preview__url">devora.vn<%= pageInfo.route %></div>
            <div class="seo-preview__desc" id="prevDesc"><%= seo.description || 'Mô tả trang sẽ hiển thị ở đây...' %></div>
          </div>
        </div>
      </div>

      <!-- Right: hình ảnh OG -->
      <div class="seo-admin-image">
        <div class="seo-admin-tab">Hình ảnh (OG Image)</div>

        <div class="seo-og-current">
          <% if (seo.og_image) { %>
            <img src="<%= seo.og_image %>" alt="OG Image" id="ogPreview">
          <% } else { %>
            <div class="seo-og-empty" id="ogEmpty">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
              <span>NO IMAGE</span>
            </div>
            <img src="" alt="OG Image" id="ogPreview" style="display:none">
          <% } %>
        </div>

        <div class="seo-og-upload" id="ogUploadArea">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.35 10.04A7.49 7.49 0 0012 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 000 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"/></svg>
          <p>Kéo và thả hình vào đây</p>
          <p>Hoặc</p>
          <button type="button" class="admin-btn admin-btn--green" id="ogChooseBtn">Chọn hình</button>
          <input type="file" name="og_image" id="ogFileInput" accept="image/*" style="display:none">
          <small>Width: 1200px × Height: 630px (jpg,gif,png,jpeg,gif,webp,WEBP)</small>
        </div>
      </div>

    </div>

    <div class="admin-form__actions" style="margin-top:24px;">
      <button type="submit" class="admin-btn admin-btn--green">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/></svg>
        Lưu SEO
      </button>
      <a href="<%= pageInfo.route %>" target="_blank" class="admin-btn admin-btn--gray">Xem trang</a>
    </div>
  </form>
</section>

<script>
// Counters
function counter(inputId, countId, barId, max) {
  const el = document.getElementById(inputId);
  const cnt = document.getElementById(countId);
  const bar = document.getElementById(barId);
  el.addEventListener('input', function() {
    const len = this.value.length;
    cnt.textContent = len;
    const pct = Math.min(len / max * 100, 100);
    bar.style.width = pct + '%';
    bar.style.background = pct > 90 ? '#e53935' : pct > 70 ? '#f59e0b' : '#1565c0';
  });
}
counter('seoTitle', 'cntTitle', 'barTitle', 70);
counter('seoKeywords', 'cntKeywords', 'barKeywords', 160);
counter('seoDesc', 'cntDesc', 'barDesc', 160);

// Live preview
document.getElementById('seoTitle').addEventListener('input', function() {
  document.getElementById('prevTitle').textContent = this.value || 'Tiêu đề trang';
});
document.getElementById('seoDesc').addEventListener('input', function() {
  document.getElementById('prevDesc').textContent = this.value || 'Mô tả trang sẽ hiển thị ở đây...';
});

// OG Image upload
const ogUploadArea = document.getElementById('ogUploadArea');
const ogFileInput  = document.getElementById('ogFileInput');
const ogPreview    = document.getElementById('ogPreview');
const ogEmpty      = document.getElementById('ogEmpty');

document.getElementById('ogChooseBtn').addEventListener('click', () => ogFileInput.click());
ogUploadArea.addEventListener('dragover', e => { e.preventDefault(); ogUploadArea.classList.add('drag-over'); });
ogUploadArea.addEventListener('dragleave', () => ogUploadArea.classList.remove('drag-over'));
ogUploadArea.addEventListener('drop', e => { e.preventDefault(); ogUploadArea.classList.remove('drag-over'); if (e.dataTransfer.files[0]) previewOg(e.dataTransfer.files[0]); });
ogFileInput.addEventListener('change', function() { if (this.files[0]) previewOg(this.files[0]); });

function previewOg(file) {
  const reader = new FileReader();
  reader.onload = e => {
    ogPreview.src = e.target.result;
    ogPreview.style.display = 'block';
    if (ogEmpty) ogEmpty.style.display = 'none';
  };
  reader.readAsDataURL(file);
  const dt = new DataTransfer(); dt.items.add(file); ogFileInput.files = dt.files;
}
</script>
