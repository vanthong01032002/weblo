<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng nhập - Hệ thống quản trị</title>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Be Vietnam Pro', Arial, sans-serif;
      min-height: 100vh;
      background: #eef0f8;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    /* Decorative blobs */
    .blob {
      position: absolute;
      border-radius: 20px;
      background: rgba(21,101,192,0.08);
      transform: rotate(-15deg);
    }
    .blob--1 { width: 200px; height: 240px; top: 8%; left: 18%; }
    .blob--2 { width: 160px; height: 200px; top: 12%; left: 26%; transform: rotate(10deg); }
    .blob--3 { width: 180px; height: 220px; bottom: 10%; right: 18%; }
    .blob--4 { width: 140px; height: 170px; bottom: 14%; right: 26%; transform: rotate(8deg); border: 2px dashed rgba(21,101,192,0.15); background: transparent; }

    /* View website link */
    .view-site {
      position: relative;
      z-index: 10;
      margin-bottom: 20px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #1565c0;
      font-size: 0.92rem;
      font-weight: 700;
      text-decoration: none;
      transition: opacity 0.15s;
    }
    .view-site:hover { opacity: 0.75; }
    .view-site svg { width: 18px; height: 18px; }

    /* Card */
    .login-card {
      position: relative;
      z-index: 10;
      background: #fff;
      border-radius: 16px;
      padding: 40px 40px 32px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.1);
    }

    /* Logo area */
    .login-logo {
      text-align: center;
      margin-bottom: 20px;
    }

    .login-logo img {
      max-height: 56px;
      max-width: 180px;
      object-fit: contain;
    }

    .login-logo__icon {
      display: inline-flex;
      align-items: center;
      gap: 2px;
      font-size: 1.6rem;
      font-weight: 900;
      color: #1565c0;
    }

    .login-logo__icon .lock {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px; height: 36px;
      background: #1565c0;
      border-radius: 8px;
      color: #fff;
      margin-left: 2px;
    }

    .login-logo__icon .lock svg { width: 20px; height: 20px; }

    .login-title {
      text-align: center;
      font-size: 1.3rem;
      font-weight: 900;
      color: #1565c0;
      letter-spacing: 0.04em;
      margin-bottom: 6px;
    }

    .login-subtitle {
      text-align: center;
      font-size: 0.88rem;
      color: #888;
      margin-bottom: 28px;
    }

    /* Error */
    .login-error {
      background: #ffebee;
      color: #c62828;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .login-error svg {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
    }

    /* Form */
    .form-group { margin-bottom: 18px; }

    .form-group label {
      display: block;
      font-size: 0.88rem;
      font-weight: 600;
      color: #333;
      margin-bottom: 6px;
    }

    .input-wrap {
      position: relative;
    }

    .input-wrap input {
      width: 100%;
      padding: 12px 44px 12px 14px;
      border: 1px solid #dde3ee;
      border-radius: 10px;
      font-size: 0.93rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      background: #fafbff;
    }

    .input-wrap input:focus {
      border-color: #1565c0;
      box-shadow: 0 0 0 3px rgba(21,101,192,0.1);
      background: #fff;
    }

    .input-wrap .input-icon {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #bbb;
      display: flex;
      align-items: center;
      cursor: pointer;
    }

    .input-wrap .input-icon svg { width: 18px; height: 18px; }

    /* Remember */
    .remember-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 22px;
    }

    .remember-row input[type="checkbox"] {
      width: 16px; height: 16px;
      accent-color: #1565c0;
      cursor: pointer;
    }

    .remember-row label {
      font-size: 0.85rem;
      color: #555;
      cursor: pointer;
    }

    /* Submit */
    .btn-login {
      width: 100%;
      padding: 14px;
      background: #1565c0;
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 800;
      font-family: inherit;
      cursor: pointer;
      letter-spacing: 0.04em;
      transition: background 0.2s, transform 0.15s;
      margin-bottom: 20px;
    }

    .btn-login:hover { background: #0d47a1; transform: translateY(-1px); }
    .btn-login:active { transform: translateY(0); }

    /* Hotline */
    .login-hotline {
      text-align: center;
      font-size: 0.88rem;
      font-weight: 700;
      color: #1565c0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }

    .login-hotline svg { width: 18px; height: 18px; }

    /* Footer */
    .login-footer {
      position: relative;
      z-index: 10;
      margin-top: 24px;
      font-size: 0.78rem;
      color: #aaa;
      text-align: center;
    }

    @media (max-width: 480px) {
      .login-card { padding: 28px 20px 24px; margin: 0 16px; }
      .blob { display: none; }
    }
  </style>
</head>
<body>

  <!-- Decorative blobs -->
  <div class="blob blob--1"></div>
  <div class="blob blob--2"></div>
  <div class="blob blob--3"></div>
  <div class="blob blob--4"></div>

  <!-- View website -->
  <a href="<%= siteUrl %>" class="view-site" target="_blank">
    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93V18c0-.55-.45-1-1-1s-1 .45-1 1v1.93C7.06 19.44 4.56 16.94 4.07 13H6c.55 0 1-.45 1-1s-.45-1-1-1H4.07C4.56 7.06 7.06 4.56 11 4.07V6c0 .55.45 1 1 1s1-.45 1-1V4.07C16.94 4.56 19.44 7.06 19.93 11H18c-.55 0-1 .45-1 1s.45 1 1 1h1.93c-.49 3.94-2.99 6.44-6.93 6.93z"/></svg>
    Xem website
  </a>

  <!-- Card -->
  <div class="login-card">

    <!-- Logo -->
    <div class="login-logo">
      <img src="/images/logo.png" alt="Logo" onerror="this.style.display='none';document.getElementById('logoFallback').style.display='flex'">
      <div class="login-logo__icon" id="logoFallback" style="display:none;">
        <span>LOG</span>
        <span class="lock">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
        </span>
        <span>IN</span>
      </div>
    </div>

    <h1 class="login-title">HỆ THỐNG QUẢN TRỊ</h1>
    <p class="login-subtitle">Vui lòng đăng nhập vào tài khoản của bạn !</p>

    <% if (error) { %>
    <div class="login-error">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
      <%= error %>
    </div>
    <% } %>

    <form action="/admin/user/login" method="POST">

      <div class="form-group">
        <label for="username">Tài khoản</label>
        <div class="input-wrap">
          <input type="text" id="username" name="username" placeholder="Tài khoản" autocomplete="username" required>
          <span class="input-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
        </div>
      </div>

      <div class="form-group">
        <label for="password">Mật khẩu</label>
        <div class="input-wrap">
          <input type="password" id="password" name="password" placeholder="············" autocomplete="current-password" required>
          <span class="input-icon" id="togglePwd" title="Hiện/ẩn mật khẩu">
            <svg id="eyeOff" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            <svg id="eyeOn" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </span>
        </div>
      </div>

      <div class="remember-row">
        <input type="checkbox" id="remember" name="remember" value="1">
        <label for="remember">Ghi nhớ đăng nhập</label>
      </div>

      <button type="submit" class="btn-login">Đăng nhập</button>

      <div class="login-hotline">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        Hotline: 028.3715.4879
      </div>

    </form>
  </div>

  <p class="login-footer">Devora &copy; <%= new Date().getFullYear() %>. All rights reserved</p>

  <script>
    const togglePwd = document.getElementById('togglePwd');
    const pwdInput  = document.getElementById('password');
    const eyeOff    = document.getElementById('eyeOff');
    const eyeOn     = document.getElementById('eyeOn');

    togglePwd.addEventListener('click', function() {
      const isHidden = pwdInput.type === 'password';
      pwdInput.type = isHidden ? 'text' : 'password';
      eyeOff.style.display = isHidden ? 'none' : '';
      eyeOn.style.display  = isHidden ? '' : 'none';
    });
  </script>
</body>
</html>
