<section class="admin-panel">
  <div class="admin-panel__head">
    <h1 class="admin-panel__title"><%= tpl ? 'Sửa giao diện' : 'Thêm giao diện mới' %></h1>
    <hr class="admin-panel__rule">
  </div>

  <form action="<%= action %>" method="POST" enctype="multipart/form-data" class="admin-form">

    <div class="admin-form__row">
      <label class="admin-form__label">Tên giao diện <span>*</span></label>
      <input type="text" name="name" class="admin-form__input" required
             value="<%= tpl ? tpl.name : '' %>" placeholder="VD: Mẫu website BĐS 1">
    </div>

    <div class="admin-form__row admin-form__row--half">
      <div>
        <label class="admin-form__label">Danh mục <span>*</span></label>
        <select name="category" class="admin-form__input">
          <% CATEGORIES.forEach(function(c) { %>
          <option value="<%= c.value %>" <%= tpl && tpl.category === c.value ? 'selected' : '' %>><%= c.label %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="admin-form__label">Số lượt sử dụng</label>
        <input type="number" name="uses" class="admin-form__input" min="0"
               value="<%= tpl ? tpl.uses : 0 %>">
      </div>
    </div>

    <div class="admin-form__row">
      <label class="admin-form__label">Mô tả ngắn</label>
      <textarea name="description" class="admin-form__input admin-form__textarea" rows="3"
                placeholder="Mô tả về giao diện này"><%= tpl ? (tpl.description||'') : '' %></textarea>
    </div>

    <div class="admin-form__row">
      <label class="admin-form__label">Hình ảnh preview <span>*</span></label>
      <div class="admin-upload-area" id="uploadArea">
        <% if (tpl && tpl.image_path) { %>
          <img src="<%= tpl.image_path %>" class="admin-upload-preview" id="imgPreview">
        <% } else { %>
          <img src="" class="admin-upload-preview" id="imgPreview" style="display:none">
        <% } %>
        <div class="admin-upload-placeholder" id="uploadPlaceholder" style="<%= tpl && tpl.image_path ? 'display:none' : '' %>">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.35 10.04A7.49 7.49 0 0012 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 000 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"/></svg>
          <p>Kéo thả hoặc <span>chọn ảnh</span></p>
          <small>Nên dùng ảnh 800×600px trở lên</small>
        </div>
        <input type="file" name="image" id="fileInput" accept="image/*" style="display:none">
      </div>
    </div>

    <div class="admin-form__row admin-form__row--half">
      <div>
        <label class="admin-form__label">Nổi bật (Ưa chuộng)</label>
        <select name="is_hot" class="admin-form__input">
          <option value="0" <%= !tpl || !tpl.is_hot ? 'selected' : '' %>>Không</option>
          <option value="1" <%= tpl && tpl.is_hot ? 'selected' : '' %>>Có (hiện badge)</option>
        </select>
      </div>
      <div>
        <label class="admin-form__label">Thứ tự hiển thị</label>
        <input type="number" name="display_order" class="admin-form__input" min="0"
               value="<%= tpl ? tpl.display_order : 0 %>">
      </div>
    </div>

    <div class="admin-form__row">
      <label class="admin-form__label">Trạng thái</label>
      <select name="is_active" class="admin-form__input" style="max-width:200px">
        <option value="1" <%= !tpl || tpl.is_active ? 'selected' : '' %>>Hiển thị</option>
        <option value="0" <%= tpl && !tpl.is_active ? 'selected' : '' %>>Ẩn</option>
      </select>
    </div>

    <div class="admin-form__actions">
      <button type="submit" class="admin-btn admin-btn--green">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/></svg>
        Lưu
      </button>
      <a href="/admin/media/templates" class="admin-btn admin-btn--gray">Hủy</a>
    </div>
  </form>
</section>

<script>
const uploadArea = document.getElementById('uploadArea');
const fileInput  = document.getElementById('fileInput');
const imgPreview = document.getElementById('imgPreview');
const placeholder = document.getElementById('uploadPlaceholder');
uploadArea.addEventListener('click', () => fileInput.click());
uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('drag-over'); });
uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('drag-over'));
uploadArea.addEventListener('drop', e => { e.preventDefault(); uploadArea.classList.remove('drag-over'); if (e.dataTransfer.files[0]) preview(e.dataTransfer.files[0]); });
fileInput.addEventListener('change', function() { if (this.files[0]) preview(this.files[0]); });
function preview(file) {
  const reader = new FileReader();
  reader.onload = e => { imgPreview.src = e.target.result; imgPreview.style.display = 'block'; placeholder.style.display = 'none'; };
  reader.readAsDataURL(file);
  const dt = new DataTransfer(); dt.items.add(file); fileInput.files = dt.files;
}
</script>
