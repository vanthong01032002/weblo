<!-- Stats row -->
<div class="dash-stats">
  <div class="dash-stat-card">
    <div class="dash-stat-card__icon" style="background:#e8f0fe;color:#1565c0;">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
    </div>
    <div>
      <div class="dash-stat-card__num"><%= totalToday %></div>
      <div class="dash-stat-card__label">Lượt xem hôm nay</div>
    </div>
  </div>
  <div class="dash-stat-card">
    <div class="dash-stat-card__icon" style="background:#e0f7fa;color:#00838f;">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
    </div>
    <div>
      <div class="dash-stat-card__num"><%= totalMonth %></div>
      <div class="dash-stat-card__label">Lượt xem 30 ngày</div>
    </div>
  </div>
  <div class="dash-stat-card">
    <div class="dash-stat-card__icon" style="background:#fff3e0;color:#e65100;">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
    </div>
    <div>
      <div class="dash-stat-card__num"><%= unreadMessages %></div>
      <div class="dash-stat-card__label">Tin nhắn chưa đọc</div>
    </div>
  </div>
  <div class="dash-stat-card">
    <div class="dash-stat-card__icon" style="background:#f3e5f5;color:#6a1b9a;">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93V18c0-.55-.45-1-1-1s-1 .45-1 1v1.93C7.06 19.44 4.56 16.94 4.07 13H6c.55 0 1-.45 1-1s-.45-1-1-1H4.07C4.56 7.06 7.06 4.56 11 4.07V6c0 .55.45 1 1 1s1-.45 1-1V4.07C16.94 4.56 19.44 7.06 19.93 11H18c-.55 0-1 .45-1 1s.45 1 1 1h1.93c-.49 3.94-2.99 6.44-6.93 6.93z"/></svg>
    </div>
    <div>
      <div class="dash-stat-card__num"><%= topIPs.length %></div>
      <div class="dash-stat-card__label">IP truy cập (30 ngày)</div>
    </div>
  </div>
</div>

<!-- Quick links -->
<section class="admin-home-panel">
  <div class="admin-home-panel__head">
    <h2 class="admin-home-panel__title" style="margin-top: 20px;margin-left: 25px;">Bảng điều khiển</h2>
    <hr class="admin-home-panel__rule">
  </div>
  <div class="admin-home-panel__body" style="margin-left: 25px;">
    <div class="admin-dash-grid">
      <a href="/admin/settings" class="admin-dash-card">
        <span class="admin-dash-card__icon admin-dash-card__icon--config">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </span>
        <span class="admin-dash-card__text">
          <span class="admin-dash-card__label">Cấu Hình Website</span>
          <span class="admin-dash-card__more">View more</span>
        </span>
      </a>
      <a href="/admin/account" class="admin-dash-card">
        <span class="admin-dash-card__icon admin-dash-card__icon--account">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </span>
        <span class="admin-dash-card__text">
          <span class="admin-dash-card__label">Tài Khoản</span>
          <span class="admin-dash-card__more">View more</span>
        </span>
      </a>
      <a href="/admin/password" class="admin-dash-card">
        <span class="admin-dash-card__icon admin-dash-card__icon--password">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </span>
        <span class="admin-dash-card__text">
          <span class="admin-dash-card__label">Đổi Mật Khẩu</span>
          <span class="admin-dash-card__more">View more</span>
        </span>
      </a>
      <a href="/admin/mail/contact" class="admin-dash-card">
        <span class="admin-dash-card__icon admin-dash-card__icon--mail">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </span>
        <span class="admin-dash-card__text">
          <span class="admin-dash-card__label">Thư Liên Hệ</span>
          <span class="admin-dash-card__more">View more <% if (unreadMessages > 0) { %><span class="dash-badge"><%= unreadMessages %></span><% } %></span>
        </span>
      </a>
    </div>
  </div>
</section>

<!-- Analytics -->
<div class="dash-analytics">

  <!-- Top IPs -->
  <section class="dash-card">
    <h3 class="dash-card__title">
      <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
      Top IP truy cập nhiều nhất
    </h3>
    <% if (topIPs.length === 0) { %>
      <p class="dash-empty">Chưa có dữ liệu</p>
    <% } else { %>
    <div class="dash-ip-list">
      <% const maxVisits = topIPs[0] ? topIPs[0].visits : 1; %>
      <% topIPs.forEach(function(row, i) { %>
      <div class="dash-ip-row">
        <span class="dash-ip-rank"><%= i + 1 %></span>
        <span class="dash-ip-addr"><%= row.ip %></span>
        <div class="dash-ip-bar-wrap">
          <div class="dash-ip-bar" style="width:<%= Math.round(row.visits / maxVisits * 100) %>%"></div>
        </div>
        <span class="dash-ip-count"><%= row.visits %></span>
      </div>
      <% }); %>
    </div>
    <% } %>
  </section>

  <!-- Browser + Device -->
  <div class="dash-col2">

    <section class="dash-card">
      <h3 class="dash-card__title">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-5 14H4v-4h11v4zm0-6H4V8h11v4zm5 6h-4V8h4v10z"/></svg>
        Trình duyệt
      </h3>
      <% if (browsers.length === 0) { %>
        <p class="dash-empty">Chưa có dữ liệu</p>
      <% } else { %>
      <% const totalBrowser = browsers.reduce((s, r) => s + r.count, 0); %>
      <div class="dash-donut-wrap">
        <canvas id="browserChart" width="160" height="160"></canvas>
        <div class="dash-legend">
          <% const bColors = ['#1565c0','#42a5f5','#0d47a1','#90caf9','#1976d2']; %>
          <% browsers.forEach(function(b, i) { %>
          <div class="dash-legend-item">
            <span class="dash-legend-dot" style="background:<%= bColors[i % bColors.length] %>"></span>
            <span><%= b.browser %></span>
            <span class="dash-legend-pct"><%= Math.round(b.count / totalBrowser * 100) %>%</span>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>
    </section>

    <section class="dash-card">
      <h3 class="dash-card__title">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14z"/></svg>
        Thiết bị truy cập
      </h3>
      <% if (devices.length === 0) { %>
        <p class="dash-empty">Chưa có dữ liệu</p>
      <% } else { %>
      <% const totalDevice = devices.reduce((s, r) => s + r.count, 0); %>
      <div class="dash-device-list">
        <% const dIcons = { Desktop: '🖥️', Mobile: '📱', Tablet: '📟' }; %>
        <% const dColors = { Desktop: '#1565c0', Mobile: '#2e7d32', Tablet: '#e65100' }; %>
        <% devices.forEach(function(d) { %>
        <div class="dash-device-row">
          <span class="dash-device-icon"><%= dIcons[d.device] || '💻' %></span>
          <div class="dash-device-info">
            <div class="dash-device-name"><%= d.device %></div>
            <div class="dash-device-bar-wrap">
              <div class="dash-device-bar" style="width:<%= Math.round(d.count / totalDevice * 100) %>%;background:<%= dColors[d.device] || '#1565c0' %>"></div>
            </div>
          </div>
          <span class="dash-device-pct"><%= Math.round(d.count / totalDevice * 100) %>%</span>
        </div>
        <% }); %>
      </div>
      <% } %>
    </section>

  </div>
</div>

<script>
// Donut chart for browsers
<% if (browsers.length > 0) { %>
(function() {
  const canvas = document.getElementById('browserChart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const data = [<%= browsers.map(b => b.count).join(',') %>];
  const colors = ['#1565c0','#42a5f5','#0d47a1','#90caf9','#1976d2'];
  const total = data.reduce((a, b) => a + b, 0);
  let start = -Math.PI / 2;
  const cx = 80, cy = 80, r = 60, inner = 36;

  data.forEach(function(val, i) {
    const angle = (val / total) * 2 * Math.PI;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, start, start + angle);
    ctx.closePath();
    ctx.fillStyle = colors[i % colors.length];
    ctx.fill();
    start += angle;
  });

  // Inner circle (donut hole)
  ctx.beginPath();
  ctx.arc(cx, cy, inner, 0, 2 * Math.PI);
  ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--admin-bg-page') || '#e8eaed';
  ctx.fill();
})();
<% } %>
</script>
