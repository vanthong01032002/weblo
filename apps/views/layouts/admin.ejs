<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin - <%= title %></title>
    <link rel="stylesheet" href="/css/admin-menu.css" />
</head>
<body class="admin-body">

    <div class="admin-sidebar-overlay" id="sidebarOverlay"></div>
    <%- include('../partials/admin_sidebar') %>

    <div class="admin-content">
        <%- include('../partials/admin_header') %>
        <main class="admin-main">
            <%- body %>
        </main>
        <footer class="admin-footer">
            © 2012, Developed by devora
        </footer>
    </div>

    <script src="/js/admin-menu.js" defer></script>
    <script>
    // ===== DARK MODE =====
    (function() {
        const saved = localStorage.getItem('adminTheme') || 'light';
        document.documentElement.setAttribute('data-theme', saved);
    })();
    </script>
    <script>
    // Mobile sidebar toggle + Dark mode
    document.addEventListener('DOMContentLoaded', function() {
        const hamburger   = document.getElementById('adminHamburger');
        const sidebar     = document.querySelector('.admin-sidebar');
        const overlay     = document.getElementById('sidebarOverlay');
        const closeBtn    = document.getElementById('sidebarClose');
        if (!hamburger || !sidebar) return;

        function openSidebar() {
            sidebar.classList.add('is-open');
            overlay.classList.add('is-open');
            document.body.style.overflow = 'hidden';
        }
        function closeSidebar() {
            sidebar.classList.remove('is-open');
            overlay.classList.remove('is-open');
            document.body.style.overflow = '';
        }

        hamburger.addEventListener('click', function() {
            sidebar.classList.contains('is-open') ? closeSidebar() : openSidebar();
        });
        overlay.addEventListener('click', closeSidebar);
        if (closeBtn) closeBtn.addEventListener('click', closeSidebar);

        // Close on nav link click (mobile)
        sidebar.querySelectorAll('a').forEach(function(a) {
            a.addEventListener('click', function() {
                if (window.innerWidth <= 768) closeSidebar();
            });
        });

        // ===== AUTO FORM ACTION BARS =====
        // Tự động thêm action bar đầu + cuối cho mọi form trong admin
        document.querySelectorAll('.admin-form').forEach(function(form) {
            const actions = form.querySelector('.admin-form__actions');
            if (!actions) return;

            // Clone cho top bar
            const topBar = document.createElement('div');
            topBar.className = 'admin-form-actions-bar admin-form-actions-bar--sticky';
            topBar.innerHTML = buildActionBar(form);
            form.insertBefore(topBar, form.firstChild);

            // Clone cho bottom bar
            const bottomBar = document.createElement('div');
            bottomBar.className = 'admin-form-actions-bar admin-form-actions-bar--bottom';
            bottomBar.innerHTML = buildActionBar(form);
            form.appendChild(bottomBar);

            // Bind submit/reset cho các nút clone
            [topBar, bottomBar].forEach(function(bar) {
                bar.querySelectorAll('[data-action]').forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        const action = this.dataset.action;
                        if (action === 'submit') form.submit();
                        if (action === 'reset')  form.reset();
                        if (action === 'back')   history.back();
                    });
                });
            });
        });

        function buildActionBar(form) {
            const submitBtn = form.querySelector('[type="submit"]');
            const cancelBtn = form.querySelector('a.admin-btn--gray, a.admin-btn[href]');
            const submitLabel = submitBtn ? submitBtn.textContent.trim() : 'Lưu';
            const cancelHref  = cancelBtn ? cancelBtn.getAttribute('href') : null;

            let html = `
              <button type="button" data-action="submit" class="admin-btn admin-btn--green">
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/></svg>
                ${submitLabel}
              </button>
              <button type="button" data-action="reset" class="admin-btn" style="background:#e65100;color:#fff;">
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg>
                Làm lại
              </button>`;

            if (cancelHref) {
                html += `<a href="${cancelHref}" class="admin-btn admin-btn--gray">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .89-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.11-.9-2-2-2z"/></svg>
                  Thoát
                </a>`;
            }
            return html;
        }

        // ===== USER DROPDOWN =====
        const userBtn      = document.getElementById('adminUserBtn');
        const userDropdown = document.getElementById('adminUserDropdown');
        if (userBtn && userDropdown) {
            userBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                const isOpen = userDropdown.classList.toggle('is-open');
                userBtn.setAttribute('aria-expanded', isOpen);
            });
            document.addEventListener('click', function() {
                userDropdown.classList.remove('is-open');
                userBtn.setAttribute('aria-expanded', 'false');
            });
            userDropdown.addEventListener('click', function(e) { e.stopPropagation(); });
        }

        // ===== DARK MODE TOGGLE =====
        const themeBtn = document.getElementById('admin-topbar-theme');
        if (themeBtn) {
            const html    = document.documentElement;
            const iconSun  = document.getElementById('icon-sun');
            const iconMoon = document.getElementById('icon-moon');

            function applyTheme(theme) {
                html.setAttribute('data-theme', theme);
                localStorage.setItem('adminTheme', theme);
                const isDark = theme === 'dark';
                themeBtn.classList.toggle('dark-active', isDark);
                if (iconSun)  iconSun.style.display  = isDark ? 'none' : '';
                if (iconMoon) iconMoon.style.display = isDark ? '' : 'none';
            }

            // Init
            applyTheme(html.getAttribute('data-theme') || 'light');

            themeBtn.addEventListener('click', function() {
                const isDark = html.getAttribute('data-theme') === 'dark';
                applyTheme(isDark ? 'light' : 'dark');
            });
        }
    });
    </script>
</body>
</html>
