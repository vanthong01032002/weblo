<header class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="header-logo">
      <% if (typeof settings !== 'undefined' && settings.logo_path) { %>
        <img src="<%= settings.logo_path %>" alt="<%= settings.site_name || 'Logo' %>" class="header-logo__img">
      <% } else { %>
        <span class="logo-w">W</span><span class="logo-text">eb<strong>top</strong></span>
      <% } %>
    </a>

    <!-- Nav -->
    <nav class="header-nav" id="headerNav">
      <ul class="nav-menu">
        <li><a href="/about">Về chúng tôi</a></li>
        <li class="has-dropdown">
          <a href="/thiet-ke-website" class="dropdown-toggle">
            Thiết kế website <span class="arrow">&#8964;</span>
          </a>
          <ul class="dropdown">
            <li><a href="/thiet-ke-website/gioi-thieu">Giới thiệu</a></li>
            <li><a href="/thiet-ke-website/bang-gia">Bảng giá</a></li>
            <li><a href="/thiet-ke-website/portfolio">Portfolio</a></li>
          </ul>
        </li>
        <li><a href="/kho-giao-dien">Kho giao diện</a></li>
        <li><a href="/dich-vu">Dịch vụ</a></li>
        <li><a href="/khach-hang">Khách hàng</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </nav>

    <!-- CTA -->
    <a href="/lien-he" class="btn-contact">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
      LIÊN HỆ
    </a>
    

    <!-- Hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Mở menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const hamburger = document.getElementById('hamburger');
    const headerNav = document.getElementById('headerNav');

    // Toggle mobile menu
    hamburger.addEventListener('click', function (e) {
      e.stopPropagation();
      const isOpen = headerNav.classList.toggle('nav-open');
      hamburger.classList.toggle('is-active', isOpen);
      hamburger.setAttribute('aria-expanded', isOpen);
    });

    // Mobile dropdown toggle (chỉ chặn navigate khi mobile)
    document.querySelectorAll('.has-dropdown > a').forEach(function (toggle) {
      toggle.addEventListener('click', function (e) {
        if (window.innerWidth <= 768) {
          e.preventDefault();
          e.stopPropagation();
          const li = this.closest('.has-dropdown');
          // Đóng các dropdown khác
          document.querySelectorAll('.has-dropdown.open').forEach(function (el) {
            if (el !== li) el.classList.remove('open');
          });
          li.classList.toggle('open');
        }
      });
    });

    // Đóng menu khi click ngoài
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.site-header')) {
        headerNav.classList.remove('nav-open');
        hamburger.classList.remove('is-active');
        hamburger.setAttribute('aria-expanded', 'false');
        document.querySelectorAll('.has-dropdown.open').forEach(function (el) {
          el.classList.remove('open');
        });
      }
    });
  });
</script>
