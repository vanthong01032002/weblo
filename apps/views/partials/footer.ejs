<footer class="site-footer">

  <!-- Main footer -->
  <div class="footer-main">
    <div class="footer-main__inner">

      <!-- Cột 1: Thông tin liên hệ -->
      <div class="footer-col">
        <h3 class="footer-col__title">Thông tin liên hệ</h3>
        <p class="footer-brand__company"><%= (typeof settings !== 'undefined' && settings.site_name) ? settings.site_name : 'Công ty TNHH Webtop' %></p>
        <ul class="footer-info">
          <li>
            <svg class="footer-info__icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            <%= (typeof settings !== 'undefined' && settings.address) ? settings.address : '213 Chu Văn An, Phường 26, Quận Bình Thạnh, TPHCM' %>
          </li>
          <li>
            <svg class="footer-info__icon" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
            Tel: <%= (typeof settings !== 'undefined' && settings.phone) ? settings.phone : '(028) 3715.4879' %>
            <% if (typeof settings !== 'undefined' && settings.phone2) { %> - <%= settings.phone2 %><% } %>
          </li>
          <li>
            <svg class="footer-info__icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            Email: <%= (typeof settings !== 'undefined' && settings.email) ? settings.email : 'info@webtop.vn' %>
          </li>
          <li>
            <svg class="footer-info__icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93V18c0-.55-.45-1-1-1s-1 .45-1 1v1.93C7.06 19.44 4.56 16.94 4.07 13H6c.55 0 1-.45 1-1s-.45-1-1-1H4.07C4.56 7.06 7.06 4.56 11 4.07V6c0 .55.45 1 1 1s1-.45 1-1V4.07C16.94 4.56 19.44 7.06 19.93 11H18c-.55 0-1 .45-1 1s.45 1 1 1h1.93c-.49 3.94-2.99 6.44-6.93 6.93z"/></svg>
            Website: <%= (typeof settings !== 'undefined' && settings.website) ? settings.website : 'www.webtop.vn' %>
          </li>
        </ul>
      </div>

      <!-- Cột 2: Chính sách dịch vụ -->
      <div class="footer-col">
        <h3 class="footer-col__title">Chính sách dịch vụ</h3>
        <ul class="footer-links">
          <li><a href="#">Quy định sử dụng dịch vụ</a></li>
          <li><a href="#">Hướng dẫn thanh toán</a></li>
          <li><a href="#">Chính sách bảo hành bảo trì</a></li>
          <li><a href="#">Chính sách bảo mật thông tin</a></li>
          <li><a href="#">Hướng dẫn quản trị website</a></li>
        </ul>
      </div>

      <!-- Cột 3: Hỗ trợ khách hàng -->
      <div class="footer-col">
        <h3 class="footer-col__title">Hỗ trợ khách hàng</h3>
        <p class="footer-support__label">Tư vấn dịch vụ 24/7:</p>
        <a href="tel:<%= (typeof settings !== 'undefined' && settings.hotline) ? settings.hotline.replace(/\./g,'') : '0912817117' %>" class="footer-support__phone">
          <%= (typeof settings !== 'undefined' && settings.hotline) ? settings.hotline : '0912.817.117' %>
        </a>
        <p class="footer-support__label" style="margin-top:10px;">Phản hồi, góp ý 24/7:</p>
        <a href="tel:<%= (typeof settings !== 'undefined' && settings.hotline2) ? settings.hotline2.replace(/\./g,'') : '0915101017' %>" class="footer-support__phone footer-support__phone--alt">
          <%= (typeof settings !== 'undefined' && settings.hotline2) ? settings.hotline2 : '0915.101.017' %>
        </a>

        <p class="footer-support__follow">Follow us:</p>
        <div class="footer-social">
          <% if (typeof socialFooter !== 'undefined' && socialFooter && socialFooter.length > 0) { %>
            <% socialFooter.forEach(function(sf) { %>
            <a href="<%= sf.link %>" class="footer-social__link" target="_blank" aria-label="<%= sf.title %>">
              <%- getSocialIcon(sf.icon_type) %>
            </a>
            <% }); %>
          <% } else { %>
            <a href="#" class="footer-social__link" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
          <% } %>
        </div>
      </div>

      <!-- Cột 4: Fanpage -->
      <div class="footer-col footer-col--fanpage">
        <h3 class="footer-col__title">Fanpage</h3>
        <div class="footer-fanpage">
          <% const embedSrc = (typeof settings !== 'undefined' && settings.fanpage_embed) ? settings.fanpage_embed : 'https://www.facebook.com/plugins/page.php?href=https%3A%2F%2Fwww.facebook.com%2Fwebtop.vn&tabs=timeline&width=260&height=200&small_header=true&adapt_container_width=true&hide_cover=false&show_facepile=true'; %>
          <iframe src="<%= embedSrc %>" width="260" height="200"
            style="border:none;overflow:hidden" scrolling="no" frameborder="0"
            allowfullscreen="true"
            allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share">
          </iframe>
        </div>
      </div>

    </div>
  </div>

  <!-- Google Maps -->
  <% if (typeof settings !== 'undefined' && settings.map_embed) { %>
  <div class="footer-map">
    <%- settings.map_embed %>
  </div>
  <% } %>

  <!-- Copyright bar -->
  <div class="footer-copy">
    <p><%= (typeof settings !== 'undefined' && settings.copyright) ? settings.copyright : 'Copyright © 2012. Bản quyền website Webtop' %></p>
  </div>

</footer>

<!-- ===== FLOATING BUTTONS (từ DB) ===== -->
<% if (typeof socialButtons !== 'undefined' && socialButtons && socialButtons.length > 0) { %>
<div class="float-btns">
  <% socialButtons.forEach(function(btn) { %>
  <a href="<%= btn.link %>"
     class="float-btn"
     style="background:<%= btn.bg_color %>;"
     <%= btn.link.startsWith('http') ? 'target="_blank"' : '' %>
     aria-label="<%= btn.title %>">
    <span class="float-btn__pulse" style="background:<%= btn.bg_color %>; opacity:0.4;"></span>
    <% if (btn.image_path) { %>
      <img src="<%= btn.image_path %>" alt="<%= btn.title %>" style="width:28px;height:28px;object-fit:contain;">
    <% } else if (btn.link.startsWith('tel:')) { %>
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
    <% } else { %>
      <span class="float-btn__label"><%= btn.title %></span>
    <% } %>
  </a>
  <% }); %>
</div>
<% } %>
